"

" Use the recommended default options
" See `:help vimrc-intro`
source $VIMRUNTIME/defaults.vim

" Add packages
packadd! matchit

" Enable line numbers
set number
set relativenumber

" Set search options
set hlsearch
set incsearch
set ignorecase
set smartcase
